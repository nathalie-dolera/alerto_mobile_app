{
  "expo": {
    "name": "alerto_frontend_mobile",
    "slug": "alerto_frontend_mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "alertofrontendmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.alerto-frontend-mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app requires your location to find the nearest places and set your destination.",
        "NSBluetoothAlwaysUsageDescription": "Allow Alerto to connect to your wearable device for alarm settings.",
        "NSBluetoothPeripheralUsageDescription": "Allow Alerto to connect to your wearable device for alarm settings.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "permissions": [
          "ACCESS_COARSE_LOCATION",
          "ACCESS_FINE_LOCATION",
          "BLUETOOTH",
          "BLUETOOTH_ADMIN",
          "BLUETOOTH_SCAN",
          "BLUETOOTH_CONNECT",
          "BLUETOOTH_ADVERTISE"
        ]
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.alertofrontendmobile",
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-secure-store",
      [
        "@maplibre/maplibre-react-native",
        {
          "android": {
            "blockAllRequest": false
          }
        }
      ],
      [
        "@config-plugins/react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": [
            "peripheral",
            "central"
          ],
          "bluetoothAlwaysPermission": "Allow Alerto to connect to your wearable device for alarm settings."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow Alerto to monitor your commute for the alarm."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Alerto to access your photos for booking verification.",
          "cameraPermission": "Allow Alerto to take photos of your booking screenshot."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {}
    }
  }
}
